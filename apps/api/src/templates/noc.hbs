<!DOCTYPE html>
<html>
<head><meta charset="utf-8">{{> base-styles}}</head>
<body>
  <div class="sheet">
    {{> letterhead}}

    <div class="doc-head">
      <div class="doc-eyebrow">To Whomsoever It May Concern</div>
      <h1 class="doc-title">No Objection Certificate</h1>
    </div>

    <div class="meta-row">
      <div>
        <span class="meta-k">Reference No.</span>
        <span class="meta-v">{{refNo}}</span>
      </div>
      <div class="right">
        <span class="meta-k">Date of Issue</span>
        <span class="meta-v">{{generatedDate}}</span>
      </div>
    </div>

    <div class="content">
      <p>
        This is to certify that <strong>{{fullName}}</strong>, employed with
        <strong>{{companyName}}</strong> as <strong>{{jobTitle}}</strong> in the
        <strong>{{department}}</strong> department since <strong>{{joinDate}}</strong>, is
        a valued member of our organisation.
      </p>
      <p>
        The company has <strong>no objection</strong>
        {{#if purpose}} to {{firstName}} {{purpose}}{{else}} to the issuance of this
        certificate for the employee's stated purpose{{/if}}, provided it does not conflict
        with the employee's duties and responsibilities towards the organisation.
      </p>
      <p>
        This certificate has been issued upon the request of the employee for official
        purposes. Should you require any clarification, please contact the People team at
        {{companyEmail}}.
      </p>

      <div class="sign">
        <p style="margin:0 0 6px; font-size:10px; color:var(--muted);">For {{companyName}},</p>
        <div class="sign__space"></div>
        <div class="sign__rule"></div>
        <div class="sign__name">{{signatoryName}}</div>
        <div class="sign__title">{{signatoryTitle}}</div>
      </div>
    </div>

    {{> footer}}
  </div>
</body>
</html>
