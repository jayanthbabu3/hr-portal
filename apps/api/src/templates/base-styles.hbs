<style>
  :root {
    --ink: #0f172a;
    --ink-soft: #334155;
    --muted: #64748b;
    --faint: #94a3b8;
    --accent: #4f46e5;
    --accent-dark: #312e81;
    --line: #e5e7eb;
    --line-soft: #eef2f7;
    --soft: #f8fafc;
    --soft-accent: #eef2ff;
  }

  * { box-sizing: border-box; }

  @page { size: A4; margin: 0; }

  html, body {
    margin: 0;
    padding: 0;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  body {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    color: var(--ink);
    font-size: 11pt;
    line-height: 1.62;
    -webkit-font-smoothing: antialiased;
  }

  .sheet {
    position: relative;
    min-height: 297mm;
    padding: 22mm 20mm 30mm;
  }

  /* ---------- Letterhead ---------- */
  .lh {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
  }
  .lh__brand { display: flex; align-items: center; gap: 14px; }
  .lh__mark {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
    color: #fff;
    font-size: 22px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0.5px;
    box-shadow: 0 6px 16px rgba(79, 70, 229, 0.28);
  }
  .lh__logo { max-height: 46px; }
  .lh__name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.2px;
    color: var(--ink);
  }
  .lh__tag {
    font-size: 9.5px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 3px;
    font-weight: 600;
  }
  .lh__contact {
    text-align: right;
    font-size: 9.5px;
    line-height: 1.7;
    color: var(--muted);
  }
  .lh__rule {
    height: 3px;
    margin: 16px 0 0;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--accent) 0%, var(--accent-dark) 60%, transparent 100%);
  }

  /* ---------- Document head ---------- */
  .doc-head { margin: 30px 0 4px; }
  .doc-eyebrow {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--faint);
    font-weight: 700;
  }
  .doc-title {
    font-size: 23px;
    font-weight: 700;
    letter-spacing: -0.3px;
    color: var(--ink);
    margin: 6px 0 0;
  }

  .meta-row {
    display: flex;
    justify-content: space-between;
    margin: 18px 0 26px;
    padding: 11px 16px;
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 10px;
    font-size: 10px;
  }
  .meta-k {
    display: block;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--faint);
    font-weight: 700;
    font-size: 8.5px;
    margin-bottom: 2px;
  }
  .meta-v { color: var(--ink); font-weight: 600; font-size: 11px; }
  .meta-row > div.right { text-align: right; }

  /* ---------- Body copy ---------- */
  .content { font-size: 11pt; color: var(--ink-soft); }
  .content p { margin: 0 0 13px; }
  .content strong { color: var(--ink); font-weight: 600; }
  .salutation { font-weight: 600; color: var(--ink); margin-bottom: 14px !important; }

  h2.section {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--accent-dark);
    margin: 26px 0 12px;
    padding-bottom: 7px;
    border-bottom: 1px solid var(--line);
  }

  /* ---------- Key-value card ---------- */
  table.kv {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    margin: 6px 0 8px;
  }
  table.kv th, table.kv td {
    padding: 11px 16px;
    font-size: 10.5px;
    text-align: left;
    border-bottom: 1px solid var(--line-soft);
    vertical-align: top;
  }
  table.kv tr:last-child th, table.kv tr:last-child td { border-bottom: 0; }
  table.kv th {
    width: 38%;
    background: var(--soft);
    color: var(--muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 9px;
    border-right: 1px solid var(--line-soft);
  }
  table.kv td { color: var(--ink); font-weight: 600; }

  /* ---------- Checklist ---------- */
  .checklist { margin: 8px 0; }
  .checklist__item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border: 1px solid var(--line);
    border-radius: 9px;
    margin-bottom: 8px;
    font-size: 10.5px;
    color: var(--ink);
    background: #fff;
  }
  .checklist__box {
    width: 16px; height: 16px;
    border: 1.5px solid var(--accent);
    border-radius: 5px;
    flex: 0 0 auto;
  }
  .checklist__tag {
    margin-left: auto;
    font-size: 8.5px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--accent);
    background: var(--soft-accent);
    padding: 3px 9px;
    border-radius: 999px;
    font-weight: 700;
  }

  /* ---------- Payslip ---------- */
  .pay-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 22px;
  }
  .pay-grid .cell {
    padding: 10px 16px;
    border-bottom: 1px solid var(--line-soft);
    border-right: 1px solid var(--line-soft);
  }
  .pay-grid .cell:nth-child(2n) { border-right: 0; }
  .pay-grid .cell .k {
    font-size: 8.5px; text-transform: uppercase; letter-spacing: 0.8px;
    color: var(--faint); font-weight: 700; margin-bottom: 2px;
  }
  .pay-grid .cell .v { font-size: 11px; font-weight: 600; color: var(--ink); }

  .pay-cols { display: flex; gap: 16px; }
  .pay-cols > div { flex: 1; }
  table.amt {
    width: 100%; border-collapse: collapse;
    border: 1px solid var(--line); border-radius: 10px; overflow: hidden;
  }
  table.amt caption {
    text-align: left; font-size: 9px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 1.2px;
    padding: 11px 14px; background: var(--soft); color: var(--ink-soft);
    border-bottom: 1px solid var(--line);
  }
  table.amt td { padding: 9px 14px; font-size: 10.5px; border-bottom: 1px solid var(--line-soft); }
  table.amt td:last-child { text-align: right; font-weight: 600; color: var(--ink); }
  table.amt tr:last-child td { border-bottom: 0; }
  table.amt tr.sum td {
    border-top: 1px solid var(--line);
    background: var(--soft); font-weight: 700; color: var(--ink);
  }
  .netbox {
    margin-top: 20px;
    display: flex; justify-content: space-between; align-items: center;
    padding: 18px 22px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
    color: #fff;
  }
  .netbox .label { font-size: 9px; letter-spacing: 1.6px; text-transform: uppercase; opacity: 0.85; font-weight: 700; }
  .netbox .words { font-size: 9.5px; opacity: 0.9; margin-top: 4px; }
  .netbox .amount { font-size: 26px; font-weight: 700; letter-spacing: -0.5px; }

  /* ---------- Signature ---------- */
  .sign { margin-top: 40px; }
  .sign__space { height: 30px; }
  .sign__name { font-size: 13px; font-weight: 700; color: var(--ink); }
  .sign__rule { width: 200px; border-top: 1px solid var(--ink); padding-top: 8px; margin-bottom: 2px; }
  .sign__title { font-size: 10px; color: var(--muted); }
  .sign-row { display: flex; justify-content: space-between; gap: 40px; margin-top: 44px; }
  .sign-row .col { flex: 1; }

  .note {
    margin-top: 22px;
    font-size: 9px;
    color: var(--faint);
    line-height: 1.6;
    border-top: 1px dashed var(--line);
    padding-top: 12px;
  }

  /* ---------- Footer ---------- */
  .foot {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    padding: 9px 20mm;
    border-top: 1px solid var(--line);
    background: #fff;
    font-size: 8px;
    color: var(--faint);
    letter-spacing: 0.3px;
    text-align: center;
  }
  .foot__row { color: var(--muted); font-weight: 600; }
  .foot__sep { margin: 0 6px; color: var(--line); }
  .foot__confidential { margin-top: 3px; font-style: italic; }
</style>
